{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "Seed three-tier design tokens (DTCG 2025.10). Tier 1 primitives are theme-agnostic; Tier 2 semantic layers (light/dark) reference them; components consume only the semantic layer. Replace values per brand; keep the structure.",
  "color": {
    "$type": "color",
    "$description": "Primitive color ramps in OKLCH. Do not reference these directly from components.",
    "gray": {
      "0": {
        "$value": {
          "colorSpace": "oklch",
          "components": [
            0.16,
            0.006,
            265
          ]
        },
        "$description": "near-black, faintly cool"
      },
      "1": {
        "$value": {
          "colorSpace": "oklch",
          "components": [
            0.99,
            0.002,
            265
          ]
        }
      },
      "2": {
        "$value": {
          "colorSpace": "oklch",
          "components": [
            0.97,
            0.003,
            265
          ]
        }
      },
      "3": {
        "$value": {
          "colorSpace": "oklch",
          "components": [
            0.94,
            0.004,
            265
          ]
        }
      },
      "6": {
        "$value": {
          "colorSpace": "oklch",
          "components": [
            0.7,
            0.006,
            265
          ]
        }
      },
      "8": {
        "$value": {
          "colorSpace": "oklch",
          "components": [
            0.55,
            0.008,
            265
          ]
        }
      },
      "11": {
        "$value": {
          "colorSpace": "oklch",
          "components": [
            0.4,
            0.01,
            265
          ]
        }
      },
      "12": {
        "$value": {
          "colorSpace": "oklch",
          "components": [
            0.24,
            0.01,
            265
          ]
        }
      }
    },
    "blue": {
      "6": {
        "$value": {
          "colorSpace": "oklch",
          "components": [
            0.62,
            0.18,
            250
          ]
        }
      },
      "9": {
        "$value": {
          "colorSpace": "oklch",
          "components": [
            0.55,
            0.2,
            250
          ]
        }
      }
    },
    "white": {
      "$value": {
        "colorSpace": "oklch",
        "components": [
          1,
          0,
          0
        ]
      }
    },
    "black": {
      "$value": {
        "colorSpace": "oklch",
        "components": [
          0,
          0,
          0
        ]
      }
    }
  },
  "space": {
    "$type": "dimension",
    "$description": "Non-linear 4px-grid spacing ramp.",
    "0": {
      "$value": {
        "value": 0,
        "unit": "px"
      }
    },
    "1": {
      "$value": {
        "value": 0.25,
        "unit": "rem"
      }
    },
    "2": {
      "$value": {
        "value": 0.5,
        "unit": "rem"
      }
    },
    "3": {
      "$value": {
        "value": 0.75,
        "unit": "rem"
      }
    },
    "4": {
      "$value": {
        "value": 1,
        "unit": "rem"
      }
    },
    "6": {
      "$value": {
        "value": 1.5,
        "unit": "rem"
      }
    },
    "8": {
      "$value": {
        "value": 2,
        "unit": "rem"
      }
    },
    "12": {
      "$value": {
        "value": 3,
        "unit": "rem"
      }
    },
    "16": {
      "$value": {
        "value": 4,
        "unit": "rem"
      }
    },
    "24": {
      "$value": {
        "value": 6,
        "unit": "rem"
      }
    }
  },
  "radius": {
    "$type": "dimension",
    "1": {
      "$value": {
        "value": 0.25,
        "unit": "rem"
      }
    },
    "2": {
      "$value": {
        "value": 0.5,
        "unit": "rem"
      }
    },
    "3": {
      "$value": {
        "value": 0.75,
        "unit": "rem"
      }
    },
    "4": {
      "$value": {
        "value": 1,
        "unit": "rem"
      }
    },
    "full": {
      "$value": {
        "value": 9999,
        "unit": "px"
      }
    }
  },
  "duration": {
    "$type": "duration",
    "$description": "Motion durations by interaction scale.",
    "1": {
      "$value": {
        "value": 120,
        "unit": "ms"
      }
    },
    "2": {
      "$value": {
        "value": 180,
        "unit": "ms"
      }
    },
    "3": {
      "$value": {
        "value": 240,
        "unit": "ms"
      }
    },
    "4": {
      "$value": {
        "value": 360,
        "unit": "ms"
      }
    }
  },
  "layout": {
    "$type": "dimension",
    "$description": "Structural layout tokens reused across all pages for cross-page coherence. Container widths in rem; the reading measure itself stays as 65ch in CSS (ch is not a DTCG unit).",
    "container-prose": {
      "$value": {
        "value": 34,
        "unit": "rem"
      }
    },
    "container-content": {
      "$value": {
        "value": 70,
        "unit": "rem"
      }
    },
    "container-wide": {
      "$value": {
        "value": 80,
        "unit": "rem"
      }
    },
    "gutter": {
      "$value": {
        "value": 1.5,
        "unit": "rem"
      }
    },
    "gutter-tight": {
      "$value": {
        "value": 1,
        "unit": "rem"
      }
    },
    "sidebar": {
      "$value": {
        "value": 16,
        "unit": "rem"
      }
    },
    "rail-collapsed": {
      "$value": {
        "value": 3.5,
        "unit": "rem"
      }
    },
    "breakpoint-sm": {
      "$value": {
        "value": 40,
        "unit": "rem"
      }
    },
    "breakpoint-md": {
      "$value": {
        "value": 48,
        "unit": "rem"
      }
    },
    "breakpoint-lg": {
      "$value": {
        "value": 64,
        "unit": "rem"
      }
    },
    "breakpoint-xl": {
      "$value": {
        "value": 80,
        "unit": "rem"
      }
    },
    "breakpoint-2xl": {
      "$value": {
        "value": 96,
        "unit": "rem"
      }
    }
  },
  "theme": {
    "$description": "Semantic tokens by role. Components consume ONLY these. Light and dark are distinct designs, not inversions.",
    "light": {
      "$type": "color",
      "bg-canvas": {
        "$value": "{color.gray.1}",
        "$description": "app background"
      },
      "bg-surface": {
        "$value": "{color.white}",
        "$description": "raised surface"
      },
      "text-primary": {
        "$value": "{color.gray.12}"
      },
      "text-muted": {
        "$value": "{color.gray.8}",
        "$description": "verify AA against bg before shipping"
      },
      "accent": {
        "$value": "{color.blue.9}"
      },
      "accent-contrast": {
        "$value": "{color.white}",
        "$description": "text on top of accent"
      },
      "border-subtle": {
        "$value": {
          "colorSpace": "oklch",
          "components": [
            0.24,
            0.01,
            265
          ],
          "alpha": 0.08
        },
        "$description": "hairline"
      },
      "border-strong": {
        "$value": {
          "colorSpace": "oklch",
          "components": [
            0.24,
            0.01,
            265
          ],
          "alpha": 0.16
        }
      }
    },
    "dark": {
      "$type": "color",
      "bg-canvas": {
        "$value": "{color.gray.0}",
        "$description": "never pure black"
      },
      "bg-surface": {
        "$value": {
          "colorSpace": "oklch",
          "components": [
            0.19,
            0.006,
            265
          ]
        }
      },
      "text-primary": {
        "$value": {
          "colorSpace": "oklch",
          "components": [
            0.95,
            0.004,
            265
          ]
        },
        "$description": "never pure white"
      },
      "text-muted": {
        "$value": "{color.gray.6}"
      },
      "accent": {
        "$value": "{color.blue.6}"
      },
      "accent-contrast": {
        "$value": "{color.gray.0}"
      },
      "border-subtle": {
        "$value": {
          "colorSpace": "oklch",
          "components": [
            1,
            0,
            0
          ],
          "alpha": 0.06
        }
      },
      "border-strong": {
        "$value": {
          "colorSpace": "oklch",
          "components": [
            1,
            0,
            0
          ],
          "alpha": 0.12
        }
      }
    }
  }
}