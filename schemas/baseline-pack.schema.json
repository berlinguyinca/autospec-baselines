{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/berlinguyinca/autospec-baselines/main/schemas/baseline-pack.schema.json",
  "title": "Autospec Structured Baseline Pack",
  "description": "Machine-readable playbook pack metadata. This is policy metadata only, not Autospec engine logic.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "title",
    "version",
    "type",
    "summary",
    "applies_when",
    "capabilities",
    "metadata_required",
    "rules",
    "quality_gates",
    "issue_templates"
  ],
  "properties": {
    "id": {"type": "string"},
    "title": {"type": "string"},
    "version": {"type": "string"},
    "type": {
      "type": "string",
      "enum": ["application", "technology", "ai", "governance", "testing", "reporting", "operations"]
    },
    "summary": {"type": "string"},
    "applies_when": {"type": "object"},
    "inherits": {"type": "array", "items": {"type": "string"}},
    "requires": {"type": "array", "items": {"type": "string"}},
    "conflicts_with": {"type": "array", "items": {"type": "string"}},
    "capabilities": {
      "type": "object",
      "required": ["required", "recommended"],
      "properties": {
        "required": {"type": "array", "items": {"type": "string"}},
        "recommended": {"type": "array", "items": {"type": "string"}}
      }
    },
    "metadata_required": {"type": "array", "items": {"type": "string"}},
    "rules": {"type": "array", "items": {"type": "object"}},
    "quality_gates": {"type": "array", "items": {"type": "string"}},
    "issue_templates": {"type": "array", "items": {"type": "object"}}
  }
}
