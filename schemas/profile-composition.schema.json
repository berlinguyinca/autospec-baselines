{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/berlinguyinca/autospec-baselines/main/schemas/profile-composition.schema.json",
  "title": "Autospec Baseline Profile Composition",
  "description": "Schema for declaring how Autospec Constitution and Autospec Baseline packs compose for a project profile. This is policy metadata only, not an engine implementation.",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "constitution", "baselines"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "constitution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository"],
      "properties": {
        "repository": {
          "type": "string",
          "const": "berlinguyinca/autospec-constitution"
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "references": {
          "$ref": "#/$defs/stringList"
        }
      }
    },
    "baselines": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "application": {
          "$ref": "#/$defs/applicationPackRefs"
        },
        "technology": {
          "$ref": "#/$defs/technologyPackRefs"
        },
        "testing": {
          "$ref": "#/$defs/testingPackRefs"
        },
        "ai": {
          "$ref": "#/$defs/aiPackRefs"
        }
      },
      "minProperties": 1
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "type": ["string", "number", "boolean", "array", "object", "null"]
      }
    },
    "exceptions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["baseline", "qualityGate", "justification", "owner", "expires"],
        "properties": {
          "baseline": {
            "$ref": "#/$defs/packRef"
          },
          "qualityGate": {
            "type": "string",
            "minLength": 1
          },
          "justification": {
            "type": "string",
            "minLength": 1
          },
          "owner": {
            "type": "string",
            "minLength": 1
          },
          "expires": {
            "type": "string",
            "format": "date"
          }
        }
      }
    },
    "conflictResolution": {
      "type": "string",
      "enum": ["stricter-gate-wins", "profile-explicit-exception-required"],
      "default": "stricter-gate-wins"
    }
  },
  "$defs": {
    "packRef": {
      "anyOf": [
        {
          "$ref": "#/$defs/packRefString"
        },
        {
          "$ref": "#/$defs/versionedPackRef"
        }
      ]
    },
    "packRefString": {
      "type": "string",
      "pattern": "^(application|technology|testing|ai)/[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "versionedPackRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": {
          "$ref": "#/$defs/packRefString"
        },
        "version": {
          "$ref": "#/$defs/semver"
        }
      }
    },
    "semver": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][A-Za-z0-9.-]+)?$"
    },
    "applicationPackRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/applicationPackEntry"
      },
      "uniqueItems": true
    },
    "technologyPackRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/technologyPackEntry"
      },
      "uniqueItems": true
    },
    "testingPackRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/testingPackEntry"
      },
      "uniqueItems": true
    },
    "aiPackRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/aiPackEntry"
      },
      "uniqueItems": true
    },
    "applicationPackEntry": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^application/[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        {
          "$ref": "#/$defs/versionedPackRefForApplication"
        }
      ]
    },
    "technologyPackEntry": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^technology/[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        {
          "$ref": "#/$defs/versionedPackRefForTechnology"
        }
      ]
    },
    "testingPackEntry": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^testing/[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        {
          "$ref": "#/$defs/versionedPackRefForTesting"
        }
      ]
    },
    "aiPackEntry": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^ai/[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        {
          "$ref": "#/$defs/versionedPackRefForAi"
        }
      ]
    },
    "versionedPackRefForApplication": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^application/[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "version": {
          "$ref": "#/$defs/semver"
        }
      }
    },
    "versionedPackRefForTechnology": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^technology/[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "version": {
          "$ref": "#/$defs/semver"
        }
      }
    },
    "versionedPackRefForTesting": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^testing/[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "version": {
          "$ref": "#/$defs/semver"
        }
      }
    },
    "versionedPackRefForAi": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^ai/[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "version": {
          "$ref": "#/$defs/semver"
        }
      }
    },
    "stringList": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  }
}
