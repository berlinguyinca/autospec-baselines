{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/berlinguyinca/autospec-baselines/main/schemas/profile-composition.schema.json",
  "title": "Autospec Baseline Profile Composition",
  "description": "A named composition of baseline packs.",
  "type": "object",
  "additionalProperties": true,
  "required": ["profile"],
  "properties": {
    "profile": {
      "type": "object",
      "required": ["id", "packs"],
      "properties": {
        "id": {"type": "string"},
        "packs": {"type": "array", "items": {"type": "string"}},
        "summary": {"type": "string"},
        "application_type": {"type": "string"},
        "maturity_target": {"type": "string"}
      }
    }
  }
}
